{% comment %}
  Artist detail: Sticky Scroll Hero Section
  - Sticky 400vh container with card peel driven by artist-content.js
  - Artist signature background (text or image for pankaj-saroj)
  - Ambient audio element
  - Sticky cards carry data attributes to populate the artwork modal
{% endcomment %}

{%- liquid
  assign artist = metaobject
  assign sticky_cards = artist.sticky_scroll.value
-%}

<!-- Ambient Audio (hidden) -->
{% if artist.audio_track != blank %}
  <audio id="artist-audio"
         src="{{ artist.audio_track.value }}"
         loop
         preload="none"></audio>
{% elsif artist.handle == 'elena' %}
  <audio id="artist-audio"
         src="{{ 'elena-piano.mp3' | asset_url }}"
         loop
         preload="none"></audio>
{% endif %}

<!-- Audio Mute/Unmute Button (fixed) -->
{% if artist.audio_track != blank or artist.handle == 'elena' %}
  <div class="fixed bottom-8 right-8 z-[100]">
    <button id="audio-play-toggle"
            class="w-12 h-12 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center hover:bg-white/20 transition-all group"
            aria-label="Toggle ambient audio">
      <span class="material-icons text-white group-hover:scale-110 transition-transform" data-audio-icon>volume_up</span>
    </button>
  </div>
{% endif %}

<!-- Sticky Scroll Container -->
<div class="sticky-scroll-container relative" style="height: 400vh;">
  <div class="sticky top-0 h-screen w-full flex items-center justify-center overflow-hidden bg-background-light dark:bg-background-dark transition-colors duration-500">

    <!-- Noise texture layer -->
    <div class="absolute inset-0 z-[1] pointer-events-none opacity-40 mix-blend-overlay"
         style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 400 400%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22nf%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23nf)%22 opacity=%221%22/%3E%3C/svg%3E');"></div>

    <!-- Artist Signature Background -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-[0] px-12 md:px-24" id="artist-signature-wrap">
      {% if artist.handle == 'pankaj-saroj' %}
        <img id="artist-signature"
             src="{{ 'pankaj-sign.png' | asset_url }}"
             alt="Pankaj Saroj signature"
             class="signature-reveal w-[150vw] md:w-[120vw] max-w-[2000px] object-contain mix-blend-multiply dark:mix-blend-screen select-none"
             style="transform: rotate(-10deg) scale(0.95);">
      {% else %}
        <span id="artist-signature"
              class="signature-reveal font-mr-de-haviland text-[#cc3333] opacity-20 whitespace-nowrap select-none text-center inline-block px-10 mix-blend-multiply dark:mix-blend-screen"
              style="font-family: var(--font-mr-de-haviland), cursive;
                     font-size: clamp(8rem, 22vw, 18rem);
                     filter: blur(3px);
                     transform: rotate(-10deg) scale(0.95);">
          {{ artist.hero_title.value | default: artist.name.value }}
        </span>
      {% endif %}
    </div>

    <!-- Card Stack -->
    <div class="card-stack relative z-10" style="width: min(180px, 42vw); height: min(340px, 70vw);"
         id="card-stack">
      {% if sticky_cards != blank and sticky_cards.size > 0 %}
        {% assign total_cards = sticky_cards.size %}
        {% for card_product in sticky_cards %}
          {%- assign card_index = forloop.index0 -%}
          {%- assign is_last = false -%}
          {%- if forloop.last -%}{%- assign is_last = true -%}{%- endif -%}
          <div class="sticky-card{% if is_last %} sticky-card--static{% endif %} artwork-card absolute inset-0 bg-white dark:bg-background-accent p-2 rounded-lg shadow-2xl {% unless is_last %}cursor-pointer{% endunless %}"
               data-card-index="{{ card_index }}"
               data-card-total="{{ total_cards }}"
               data-artwork-id="{{ card_product.id }}"
               data-image="{{ card_product.featured_image | image_url: width: 1200 }}"
               data-title="{{ card_product.title | escape }}"
               data-price="{{ card_product.price | money }}"
               data-description="{{ card_product.description | strip_html | truncatewords: 50 | escape }}"
               data-url="{{ card_product.url }}"
               style="z-index: {{ 40 | minus: card_index }}; transform: rotate({{ card_index | modulo: 2 | times: 4 | minus: 2 }}deg);">
            {% if card_product.featured_image != blank %}
              <img src="{{ card_product.featured_image | image_url: width: 1000 }}"
                   alt="{{ card_product.title | escape }}"
                   class="w-full h-full object-cover rounded"
                   loading="eager">
            {% else %}
              <div class="w-full h-full bg-slate-200 dark:bg-primary/30 rounded flex items-center justify-center">
                <span class="text-xs text-slate-400 uppercase tracking-widest text-center px-4">{{ card_product.title }}</span>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      {% else %}
        <div class="sticky-card sticky-card--static absolute inset-0 bg-white dark:bg-background-accent p-2 rounded-lg shadow-2xl">
          <div class="w-full h-full bg-slate-200 dark:bg-primary/30 rounded flex items-center justify-center text-xs text-slate-400">
            No highlights
          </div>
        </div>
      {% endif %}
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-50 animate-bounce">
      <span class="text-[10px] font-mono tracking-[0.2em] text-slate-400 uppercase mix-blend-difference">Scroll</span>
      <span class="material-icons text-slate-400 text-sm mix-blend-difference">keyboard_arrow_down</span>
    </div>

  </div>
</div>

<!-- Artwork Modal (populated by artist-content.js) -->
{% render 'artwork-modal' %}

{% schema %}
{
  "name": "Artist Hero",
  "settings": [],
  "presets": [
    {
      "name": "Artist Sticky Hero"
    }
  ]
}
{% endschema %}
