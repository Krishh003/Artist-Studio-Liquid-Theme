{% comment %}
  Artist detail: Fullscreen Hero Section
  - h-screen with noise + crosshatch overlays
  - Artist signature clip-path wipe-in reveal
  - Hero image (portrait) centered below signature
  - Ambient audio element
  - Scroll indicator
{% endcomment %}

{%- assign artist = metaobject -%}

<!-- Ambient Audio -->
{% if artist.audio_track != blank %}
  <audio id="artist-audio"
         src="{{ artist.audio_track.value }}"
         loop
         preload="none"></audio>
{% elsif artist.system.handle == 'elena' %}
  <audio id="artist-audio"
         src="{{ 'elena-piano.mp3' | asset_url }}"
         loop
         preload="none"></audio>
{% endif %}

<!-- Audio Toggle (fixed) -->
{% if artist.audio_track != blank or artist.system.handle == 'elena' %}
  <div class="fixed bottom-8 right-8" style="z-index: 100;">
    <button id="audio-play-toggle"
            aria-label="Toggle ambient audio"
            style="width: 3rem; height: 3rem; border-radius: 9999px;
                   background: rgba(255,255,255,0.1); backdrop-filter: blur(12px);
                   border: 1px solid rgba(255,255,255,0.2); display: flex;
                   align-items: center; justify-content: center;
                   transition: background 0.2s; cursor: pointer;">
      <span class="material-icons" data-audio-icon style="color: white; font-size: 1.25rem;">volume_up</span>
    </button>
  </div>
{% endif %}

<!-- Fullscreen Hero -->
<section class="hero-section relative overflow-hidden bg-background-light dark:bg-black"
         style="height: 100vh;">

  <!-- Noise texture -->
  <div class="absolute inset-0 pointer-events-none"
       style="z-index: 0; opacity: 0.4; mix-blend-mode: overlay;
              background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 400 400%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22nf%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23nf)%22 opacity=%221%22/%3E%3C/svg%3E');"></div>

  <!-- Crosshatch grid -->
  <div class="absolute inset-0 pointer-events-none"
       style="z-index: 0; opacity: 0.3; mix-blend-mode: multiply;
              background-image: repeating-linear-gradient(0deg, transparent, transparent 49px, rgba(0,0,0,0.08) 49px, rgba(0,0,0,0.08) 50px),
                                repeating-linear-gradient(90deg, transparent, transparent 49px, rgba(0,0,0,0.08) 49px, rgba(0,0,0,0.08) 50px);"></div>

  <!-- Signature background -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none px-12"
       style="z-index: 1;">
    {% if artist.signature_image != blank %}
      <img id="artist-signature"
           src="{{ artist.signature_image.value | image_url: width: 2000 }}"
           alt="{{ artist.name.value | escape }} signature"
           width="{{ artist.signature_image.value.width | default: 2000 }}"
           height="{{ artist.signature_image.value.height | default: 600 }}"
           class="signature-reveal dark:invert select-none"
           style="width: min(150vw, 2000px); max-width: 2000px; height: auto;
                  mix-blend-mode: darken; transform: rotate(-10deg) scale(0.95);">
    {% else %}
      <span id="artist-signature"
            class="signature-reveal select-none text-center"
            style="font-family: var(--font-cursive, cursive);
                   font-size: clamp(8rem, 22vw, 18rem);
                   color: #cc3333; opacity: 0.35;
                   white-space: nowrap; display: inline-block; padding: 0 2.5rem;
                   mix-blend-mode: darken; filter: blur(1.5px);
                   transform: rotate(-10deg) scale(0.95);">
        {{ artist.hero_title.value | default: artist.name.value }}
      </span>
    {% endif %}
  </div>

  <!-- Hero portrait -->
  <div class="absolute inset-0 flex items-center justify-center" style="z-index: 2;">
    {% if artist.hero_image != blank %}
      <img src="{{ artist.hero_image.value | image_url: width: 800 }}"
           alt="{{ artist.name.value | escape }}"
           width="{{ artist.hero_image.value.width }}"
           height="{{ artist.hero_image.value.height }}"
           class="hero-portrait-fade"
           style="max-height: 40vh; width: auto; height: auto; display: block; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);">
    {% endif %}
  </div>

  <!-- Scroll indicator -->
  <div class="absolute flex flex-col items-center gap-2 animate-bounce"
       style="bottom: 2rem; left: 50%; transform: translateX(-50%); z-index: 10;">
    <span style="font-size: 0.625rem; font-family: monospace; letter-spacing: 0.2em;
                 color: #94a3b8; text-transform: uppercase; mix-blend-mode: difference;">Scroll</span>
    <span class="material-icons" style="color: #94a3b8; font-size: 1rem; mix-blend-mode: difference;">keyboard_arrow_down</span>
  </div>

</section>

<!-- Artwork Modal (populated by artist-content.js) -->
{% render 'artwork-modal' %}

<style>
  .dark .hero-section {
    background-color: #000;
  }

  .dark .hero-section > div:nth-child(2) {
    opacity: 0.28;
  }

  .dark .hero-section > div:nth-child(3) {
    opacity: 0.16;
    mix-blend-mode: screen !important;
  }

  .dark .hero-section #artist-signature {
    mix-blend-mode: screen !important;
  }

  .dark .hero-section span#artist-signature {
    color: rgba(229, 228, 215, 0.5) !important;
  }
</style>

{% schema %}
{
  "name": "Artist Hero",
  "settings": [],
  "presets": [
    {
      "name": "Artist Fullscreen Hero"
    }
  ]
}
{% endschema %}
