{% comment %}
  Artists listing page — matches the original Next.js /artists route.
  Layout: page header (H1 + subtitle) → 2-column card grid.
  Each card delegates to snippets/artist-card.liquid.
  Entrance animations handled by assets/artists-list.js.
{% endcomment %}

<div class="bg-background-light dark:bg-background-dark"
     style="min-height: 100vh; padding-top: 8rem; padding-bottom: 5rem;">
  <div style="max-width: 80rem; margin: 0 auto; padding: 0 1.5rem;">

    <!-- Page header -->
    <header style="margin-bottom: 5rem; text-align: center;">
      <h1 class="font-serif reveal"
          style="font-size: clamp(2.25rem, 6vw, 4.5rem); font-weight: 700;
                 margin-bottom: 1.5rem; line-height: 1.1;">
        Collaborating Artists
      </h1>
      <p class="text-slate-600 dark:text-text-muted reveal reveal-stagger-1"
         style="max-width: 42rem; margin: 0 auto; font-size: 1.125rem;
                font-weight: 300; line-height: 1.625;">
        Meet the visionaries who are redefining the boundaries of physical and digital art.
        Each artist brings a unique perspective to the Pristine Forests collective.
      </p>
    </header>

    <!-- Artist grid -->
    <div class="artists-page-grid">
      {%- assign artist_count = 0 -%}
      {% for artist in shop.metaobjects['artist'].values %}
        {% unless artist.handle == 'pf-artist' %}
          {%- assign artist_count = artist_count | plus: 1 -%}
          {% render 'artist-card', artist: artist, index: forloop.index0 %}
        {% endunless %}
      {% endfor %}
    </div>

    {% if artist_count == 0 %}
      <p class="text-slate-400 dark:text-text-muted text-sm uppercase tracking-widest text-center py-16 reveal"
         style="max-width: 42rem; margin: 0 auto;">
        No artists to display yet.
      </p>
    {% endif %}

  </div>
</div>

<style>
  .artists-page-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .artists-page-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem;
    }
  }
</style>

{% schema %}
{
  "name": "Artists List",
  "settings": [],
  "presets": [
    {
      "name": "Artists Grid"
    }
  ]
}
{% endschema %}
