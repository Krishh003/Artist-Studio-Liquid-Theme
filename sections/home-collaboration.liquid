{%- liquid
  assign site_settings = shop.metaobjects['site_settings']['artist-studio-by-pristine-forests']
-%}

<section class="py-24 px-6 md:px-12 bg-background-light dark:bg-background-dark transition-colors duration-300 relative overflow-hidden">
  
  <!-- Subtle gold background gradient -->
  <div class="absolute inset-0 z-0 bg-gradient-to-br from-gold/5 via-transparent to-transparent opacity-50 pointer-events-none"></div>

  <div class="container max-w-7xl mx-auto relative z-10">
    
    <header class="mb-24 text-center flex flex-col items-center">
      <h2 class="w-full text-4xl sm:text-6xl md:text-8xl lg:text-9xl font-serif font-normal text-slate-900 dark:text-text-light mb-8 uppercase tracking-tighter leading-none reveal">
        Collaboration
      </h2>
      <div class="h-[1px] w-32 bg-[#31544E] mx-auto origin-center reveal reveal-stagger-1"></div>
    </header>

    <div class="space-y-24">
      
      <!-- What is Artist Studio? -->
      {% if site_settings.collab_what_body.value != blank %}
        <div class="max-w-3xl reveal reveal-stagger-2">
           <h3 class="font-serif text-2xl md:text-3xl text-slate-900 dark:text-text-light uppercase tracking-tight mb-6">
              What is Artist Studio?
           </h3>
           <div class="text-sm text-slate-500 dark:text-text-muted leading-relaxed space-y-4">
              {{ site_settings.collab_what_body.value | newline_to_br }}
           </div>
        </div>
      {% endif %}

      <!-- Why We Do It -->
      {% if site_settings.collab_why_body.value != blank %}
        <div class="max-w-3xl ml-auto reveal reveal-stagger-3 text-right">
           <h3 class="font-serif text-2xl md:text-3xl text-slate-900 dark:text-text-light uppercase tracking-tight mb-6">
              Why We Do It
           </h3>
           <div class="text-sm text-slate-500 dark:text-text-muted leading-relaxed space-y-4">
              {{ site_settings.collab_why_body.value | newline_to_br }}
           </div>
        </div>
      {% endif %}

      <!-- And There's Something Extra -->
      {% if site_settings.collab_extra_body.value != blank or site_settings.artist_discount_code.value != blank %}
        <div class="bg-[#E5E4D7] dark:bg-[#1B3B36] p-10 md:p-16 rounded-sm border border-slate-300 dark:border-primary/10 text-center reveal reveal-stagger-4">
           <h3 class="font-serif text-2xl md:text-3xl text-slate-900 dark:text-white uppercase tracking-tight mb-6">
              And There's Something Extra
           </h3>
           {% if site_settings.collab_extra_body.value != blank %}
              <div class="text-sm text-slate-500 dark:text-text-muted leading-relaxed space-y-4 max-w-2xl mx-auto mb-10">
                 {{ site_settings.collab_extra_body.value | newline_to_br }}
              </div>
           {% endif %}
           {% if site_settings.artist_discount_code.value != blank %}
              <p class="text-xs font-bold tracking-widest text-[#31544E] dark:text-[#E5E4D7] uppercase">
                 Use code
                 <span class="inline-block bg-[#31544E] dark:bg-[#E5E4D7] text-white dark:text-[#1B3B36] px-3 py-1 rounded font-mono tracking-wider">
                    {{ site_settings.artist_discount_code.value }}
                 </span>
                 at checkout
              </p>
           {% endif %}
        </div>
      {% endif %}

    </div>
  </div>

</section>

{% schema %}
{
  "name": "Home Collaboration",
  "settings": [],
  "presets": [
    {
      "name": "Home Collaboration"
    }
  ]
}
{% endschema %}
