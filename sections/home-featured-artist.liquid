{%- liquid
  assign site_settings = shop.metaobjects['site_settings']['artist-studio-by-pristine-forests']
  assign featured_artist = site_settings.featured_artist.value

  if featured_artist != blank
    assign artworks = featured_artist.sticky_scroll.value
    
    if artworks == blank or artworks.size == 0
      assign artworks = collections[featured_artist.handle].products
    endif

    if artworks == blank or artworks.size == 0
      assign artworks = collections.all.products | where: 'vendor', featured_artist.name.value
    endif

    if artworks == blank or artworks.size == 0
       # Fallback to general products if absolutely nothing matches
       assign artworks = collections.all.products
    endif
  endif
-%}


<section class="py-24 px-6 md:px-12 bg-background-light-accent dark:bg-background-accent relative z-30 transition-colors duration-300">
  
  <div class="container max-w-7xl mx-auto">
    <div class="mb-16 border-b border-slate-300 dark:border-primary/20 pb-8 reveal">
      <h2 class="font-serif text-3xl md:text-4xl font-normal text-slate-900 dark:text-text-light mb-4 uppercase tracking-tighter">
        {{ site_settings.featured_artist_heading.value | default: "Featured Artist" }}
      </h2>
    </div>

    {% if featured_artist != blank %}
      <div class="flex flex-col lg:flex-row gap-12 items-center relative z-10">
        
        <!-- Left column: artist info (taking up some space) -->
        <div class="flex flex-col gap-6 lg:w-1/3 flex-shrink-0">
          <div class="flex items-end gap-6 reveal reveal-stagger-1">
            {% if featured_artist.profile_image != blank %}
              <div class="relative w-28 h-28 md:w-32 md:h-32 flex-shrink-0 rounded-full overflow-hidden border-4 border-[#C5A059] shadow-xl">
                {{ featured_artist.profile_image.value | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
              </div>
            {% endif %}
            <div>
              <span class="text-[10px] font-bold tracking-[0.2em] text-[#C5A059] uppercase mb-1 block">
                {{ featured_artist.category.value | default: "Featured Artist" }}
              </span>
              <h3 class="font-serif text-4xl md:text-5xl text-slate-900 dark:text-text-light uppercase leading-none">
                {{ featured_artist.name.value }}
              </h3>
            </div>
          </div>

          <p class="text-slate-500 dark:text-text-muted text-sm leading-relaxed reveal reveal-stagger-2">
            {{ site_settings.featured_artist_intro.value | default: featured_artist.short_bio.value | default: "Explore the evocative works of this talented artist, known for capturing the essence of the natural world through a masterly blend of light and color." }}
          </p>

          <a href="{{ featured_artist.system.url | default: "#" }}" 
             class="inline-flex items-center gap-2 px-8 py-3 bg-[#31544E] text-white rounded-full text-xs font-semibold tracking-widest uppercase hover:bg-[#1B3B36] transition-all duration-300 self-start reveal reveal-stagger-3">
            Explore His Art <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>

        <!-- Right column/area: horizontal infinite carousel -->
        <div class="reveal reveal-stagger-4 w-full overflow-hidden lg:w-2/3">
           {% comment %} 
             Increase/Decrease Speed: Adjust the 'speed' parameter below (e.g., '20s' is faster than '40s').
           {% endcomment %}
           {% render 'featured-carousel', artworks: artworks, speed: '20s' %}
        </div>
      </div>
    {% else %}
      <p class="text-slate-400 dark:text-text-muted text-sm uppercase tracking-widest text-center py-16 reveal">
        No featured artist set. Add one in the CMS.
      </p>
    {% endif %}
  </div>

  <!-- Background Decorative Signature -->
  <div class="absolute top-1/2 -right-8 -translate-y-1/2 -rotate-90 hidden lg:block pointer-events-none reveal opacity-10">
    <span class="text-9xl text-slate-900 dark:text-text-light font-cursive whitespace-nowrap italic">
      {{ featured_artist.name.value }}
    </span>
  </div>

</section>

{% schema %}
{
  "name": "Featured Artist",
  "settings": [],
  "presets": [
    {
      "name": "Home Featured Artist"
    }
  ]
}
{% endschema %}
