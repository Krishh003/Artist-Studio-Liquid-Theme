{%- liquid
  assign site_settings = shop.metaobjects['site_settings']['artist-studio-by-pristine-forests']
-%}
<footer class="bg-[#0E120E] text-text-light pt-32 pb-16 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Main Footer Content Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 mb-32">
      
      <!-- Column 1: Brand & Bio -->
      <div class="lg:col-span-4 max-w-sm">
        <a href="{{ routes.root_url }}" class="text-3xl font-serif font-normal tracking-tight text-white mb-10 block">Pristine Forests</a>
        <p class="text-text-muted text-[15px] leading-relaxed mb-10 font-normal">
          {{ site_settings.footer_tagline.value | default: "An experimental platform dedicated to the intersection of art and beauty." }}
        </p>
        <!-- Social Icons - ENLARGED -->
        <div class="flex space-x-4">
          <a href="#" aria-label="Facebook" class="w-12 h-12 flex items-center justify-center rounded-full bg-[#1B3B36] text-white hover:bg-primary transition-all group">
             <span class="material-icons text-xl group-hover:scale-110 transition-transform">facebook</span>
          </a>
          <a href="#" aria-label="LinkedIn" class="w-12 h-12 flex items-center justify-center rounded-full bg-[#1B3B36] text-white hover:bg-primary transition-all group">
             <span class="material-icons text-xl group-hover:scale-110 transition-transform">linkedin</span>
          </a>
          <a href="#" aria-label="Share" class="w-12 h-12 flex items-center justify-center rounded-full bg-[#1B3B36] text-white hover:bg-primary transition-all group">
             <span class="material-icons text-xl group-hover:scale-110 transition-transform">share</span>
          </a>
        </div>
      </div>

      <!-- Column 2: Platform -->
      <div class="lg:col-span-2">
         <h4 class="font-serif font-bold text-white text-base mb-8">Platform</h4>
         <ul class="space-y-5 text-[15px] text-text-muted font-normal">
            <li><a href="/pages/artists" class="hover:text-white transition-colors">Artist Directory</a></li>
            <li><a href="{{ routes.all_products_collection_url }}" class="hover:text-white transition-colors">Store</a></li>
         </ul>
      </div>

      <!-- Column 3: Company -->
      <div class="lg:col-span-2">
         <h4 class="font-serif font-bold text-white text-base mb-8">Company</h4>
         <ul class="space-y-5 text-[15px] text-text-muted font-normal">
            <li>
              <a href="https://admin.shopify.com" target="_blank" class="hover:text-white transition-colors flex items-center gap-2">
                Admin Login <span class="material-icons text-lg">lock</span>
              </a>
            </li>
         </ul>
      </div>

      <!-- Column 4: Newsletter -->
      <div class="lg:col-span-4">
         <h4 class="font-serif font-bold text-white text-base mb-8">Newsletter</h4>
         <p class="text-[15px] text-text-muted mb-6 font-normal">Subscribe for art drops.</p>
         <form class="flex flex-col gap-3 w-full max-w-[320px]">
            <input class="w-full bg-[#1B3B36] border-none rounded-sm px-5 py-4 text-sm text-white placeholder-text-muted/30 focus:ring-1 focus:ring-primary outline-none transition-all"
               placeholder="Email Address" type="email" aria-label="Email Address">
            <button class="w-full bg-[#2D4D47] text-white rounded-sm px-5 py-3.5 text-sm font-bold hover:bg-primary transition-all tracking-wider" type="button">
               Join
            </button>
         </form>
      </div>
    </div>
    
    <!-- Footer Bottom -->
    <div class="border-t border-white/5 pt-12 flex flex-col md:flex-row justify-between items-center gap-6 text-[13px] text-text-muted/40 font-normal">
      <p>© 2026 Pristine Forests. All rights reserved.</p>
      <div class="flex gap-10">
        <a href="/pages/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/pages/terms" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [],
  "presets": [
    {
      "name": "Default Footer"
    }
  ]
}
{% endschema %}
