{%- liquid
  assign site_settings = shop.metaobjects['site_settings']['artist-studio-by-pristine-forests']
-%}
<footer class="site-footer">
  <div class="footer__inner">

    <!-- Top Section: Brand + 3-Column Grid -->
    <div class="footer__top">

      <!-- Brand Column -->
      <div class="footer__brand">
        <a href="{{ routes.root_url }}" class="footer__logo">Pristine Forests</a>
        <p class="footer__tagline">
          An experimental platform dedicated to the intersection of art and beauty.
        </p>

        <!-- Social Icons -->
        <div class="footer__socials">
          <a href="https://www.facebook.com/PristineForests" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="footer__social-btn">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/pristine-forests" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="footer__social-btn">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
          <button data-footer-share aria-label="Share this page" class="footer__social-btn">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"/></svg>
          </button>
        </div>
      </div>

      <!-- Right: 3-Column Grid -->
      <div class="footer__grid">

        <!-- Platform -->
        <div>
          <h4 class="footer__col-heading">Platform</h4>
          <ul class="footer__col-list">
            <li><a href="/pages/artists">Artist Directory</a></li>
            <li><a href="https://www.pristineforests.com">Store</a></li>
          </ul>
        </div>

        <!-- Company -->
        <div>
          <h4 class="footer__col-heading">Company</h4>
          <ul class="footer__col-list">
            <li>
              <a href="https://admin.shopify.com" target="_blank" rel="noopener noreferrer" class="footer__admin-link">
                Admin Login
                <svg width="10" height="10" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M10 2a4 4 0 00-4 4v2H5v10h10V8h-1V6a4 4 0 00-4-4zm2 6H8V6a2 2 0 114 0v2z"/></svg>
              </a>
            </li>
          </ul>
        </div>

        <!-- Newsletter -->
        <div>
          <h4 class="footer__col-heading">Newsletter</h4>
          <p class="footer__newsletter-text">Subscribe for art drops.</p>
          <form class="footer__newsletter-form" action="/contact#contact_form" method="post" accept-charset="UTF-8">
            <input type="hidden" name="form_type" value="customer">
            <input type="hidden" name="utf8" value="✓">
            <input
              class="footer__newsletter-input"
              type="email"
              name="contact[email]"
              placeholder="Email Address"
              aria-label="Email Address"
              required
            >
            <button class="footer__newsletter-btn" type="submit">Join</button>
          </form>
        </div>

      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer__bottom">
      <p>&copy; 2026 Pristine Forests. All rights reserved.</p>
      <div class="footer__bottom-links">
        <a href="https://www.pristineforests.com/policies/privacy-policy">Privacy Policy</a>
        <a href="https://www.pristineforests.com/policies/terms-of-service">Terms of Service</a>
      </div>
    </div>

  </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var shareBtn = document.querySelector('[data-footer-share]');
    if (!shareBtn) return;
    shareBtn.addEventListener('click', async function () {
      if (navigator.share) {
        try {
          await navigator.share({
            title: 'Pristine Forests - Artist Studio',
            url: window.location.href
          });
        } catch (e) {
          // user cancelled — no action needed
        }
      } else {
        navigator.clipboard.writeText(window.location.href);
        alert('Link copied to clipboard!');
      }
    });
  });
</script>

{% schema %}
{
  "name": "Footer",
  "settings": [],
  "presets": [
    {
      "name": "Default Footer"
    }
  ]
}
{% endschema %}
