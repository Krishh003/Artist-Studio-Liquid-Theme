{%- liquid
  assign site_settings = shop.metaobjects['site_settings']['artist-studio-by-pristine-forests']
-%}
<footer class="bg-[#0E100E] text-white pt-40 pb-20 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    
    <!-- Top Section: 4-Column Balanced Layout -->
    <div class="flex flex-col lg:flex-row justify-between items-start gap-16 lg:gap-8 mb-40">
      
      <!-- Brand Column -->
      <div class="flex-1 lg:max-w-sm">
        <a href="{{ routes.root_url }}" class="text-4xl font-serif font-normal tracking-tight text-white mb-10 block">Pristine Forests</a>
        <p class="text-[#8E9D9B] text-base leading-relaxed mb-12 font-normal max-w-[280px]">
          An experimental platform dedicated to the intersection of art and beauty.
        </p>
        
        <!-- Social Logos - Large and Distinct -->
        <div class="flex space-x-6">
          <a href="#" aria-label="Facebook" class="w-14 h-14 flex items-center justify-center rounded-full bg-[#1B3632] hover:bg-[#31544E] transition-all">
            <svg class="w-6 h-6 fill-white" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" aria-label="LinkedIn" class="w-14 h-14 flex items-center justify-center rounded-full bg-[#1B3632] hover:bg-[#31544E] transition-all">
            <svg class="w-6 h-6 fill-white" viewBox="0 0 24 24"><path d="M22.23 0H1.77C.8 0 0 .77 0 1.72v20.56C0 23.23.8 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.2 0 22.23 0zM7.12 20.45H3.56V9h3.56v11.45zM5.34 7.43c-1.14 0-2.06-.92-2.06-2.06 0-1.14.92-2.06 2.06-2.06 1.14 0 2.06.92 2.06 2.06 0 1.14-.92 2.06-2.06 2.06zM20.45 20.45h-3.56v-5.6c0-1.34-.03-3.06-1.87-3.06-1.87 0-2.15 1.46-2.15 2.96v5.7h-3.56V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29z"/></svg>
          </a>
          <a href="#" aria-label="Share" class="w-14 h-14 flex items-center justify-center rounded-full bg-[#1B3632] hover:bg-[#31544E] transition-all">
            <svg class="w-6 h-6 fill-white" viewBox="0 0 24 24"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"/></svg>
          </a>
        </div>
      </div>

      <!-- Platform Column -->
      <div class="lg:w-48">
         <h4 class="font-serif font-bold text-white text-xl mb-10">Platform</h4>
         <ul class="space-y-6 text-[#8E9D9B] text-base">
            <li><a href="/pages/artists" class="hover:text-white transition-colors">Artist Directory</a></li>
            <li><a href="{{ routes.all_products_collection_url }}" class="hover:text-white transition-colors">Store</a></li>
         </ul>
      </div>

      <!-- Company Column -->
      <div class="lg:w-48">
         <h4 class="font-serif font-bold text-white text-xl mb-10">Company</h4>
         <ul class="space-y-6 text-[#8E9D9B] text-base">
            <li>
              <a href="https://admin.shopify.com" target="_blank" class="hover:text-white transition-colors flex items-center gap-3">
                Admin Login 
                <svg class="w-4 h-4 fill-white" viewBox="0 0 20 20"><path d="M10 2a4 4 0 00-4 4v2H5v10h10V8h-1V6a4 4 0 00-4-4zm2 6H8V6a2 2 0 114 0v2z"/></svg>
              </a>
            </li>
         </ul>
      </div>

      <!-- Newsletter Column -->
      <div class="lg:w-80">
         <h4 class="font-serif font-bold text-white text-xl mb-10">Newsletter</h4>
         <p class="text-[#8E9D9B] text-base mb-8">Subscribe for art drops.</p>
         <form class="flex flex-col gap-4">
            <input class="w-full bg-[#1B3632] border-none rounded-sm px-6 py-4 text-sm text-white placeholder-[#4A5D5A] outline-none transition-all"
               placeholder="Email Address" type="email" aria-label="Email Address">
            <button class="w-full bg-[#2D4D47] text-white rounded-sm px-6 py-4 text-sm font-bold hover:bg-[#31544E] transition-all tracking-widest uppercase" type="button">
               Join
            </button>
         </form>
      </div>
    </div>
    
    <!-- Bottom Bar: Alignment matched one-to-one -->
    <div class="pt-16 flex flex-col md:flex-row justify-between items-center gap-8 border-t border-white/5 text-[12px] text-[#4A5D5A] tracking-[0.1em] uppercase">
      <p>© 2026 Pristine Forests. All rights reserved.</p>
      <div class="flex gap-12">
        <a href="/pages/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/pages/terms" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [],
  "presets": [
    {
      "name": "Default Footer"
    }
  ]
}
{% endschema %}
