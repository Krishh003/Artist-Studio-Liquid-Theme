{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "An experimental platform dedicated to the intersection of art and beauty."
    }
  ]
}
{% endschema %}

<footer class="bg-slate-100 border-t border-slate-200 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Top Section -->
    <div class="flex flex-col lg:flex-row justify-between items-start gap-12 mb-16">

      <!-- Brand -->
      <div class="max-w-xs">
        <a href="{{ routes.root_url }}" class="text-2xl font-serif font-bold tracking-tight text-slate-900 mb-6 block hover:opacity-80 transition-opacity">
          {{ shop.name }}
        </a>

        <p class="text-slate-600 text-sm leading-relaxed mb-6 font-light">
          {{ section.settings.tagline }}
        </p>

        <!-- Social -->
        <div class="flex space-x-4 mt-6">
          {% if settings.social_facebook_link != blank %}
            <a href="{{ settings.social_facebook_link }}" target="_blank" class="w-11 h-11 flex items-center justify-center rounded-full bg-gray-200 hover:bg-black hover:text-white transition-colors">
              FB
            </a>
          {% endif %}

          {% if settings.social_linkedin_link != blank %}
            <a href="{{ settings.social_linkedin_link }}" target="_blank" class="w-11 h-11 flex items-center justify-center rounded-full bg-gray-200 hover:bg-black hover:text-white transition-colors">
              IN
            </a>
          {% endif %}

          <!-- Share -->
          <button onclick="navigator.clipboard.writeText(window.location.href); alert('Link copied!')"
            class="w-11 h-11 flex items-center justify-center rounded-full bg-gray-200 hover:bg-black hover:text-white transition-colors">
            ↗
          </button>
        </div>
      </div>

      <!-- Links Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 md:gap-12 lg:gap-24 w-full lg:w-auto">

        <!-- Platform -->
        <div>
          <h4 class="font-serif font-bold text-slate-900 mb-4 md:mb-6">Platform</h4>
          <ul class="space-y-3 md:space-y-4 text-sm text-slate-600 font-light">
            <li><a href="/pages/artists" class="hover:text-black">Artist Directory</a></li>
            <li><a href="{{ routes.root_url }}" class="hover:text-black">Store</a></li>
          </ul>
        </div>

        <!-- Company -->
        <div>
          <h4 class="font-serif font-bold text-slate-900 mb-4 md:mb-6">Company</h4>
          <ul class="space-y-3 md:space-y-4 text-sm text-slate-600 font-light">
            <li>
              <a href="/admin" class="hover:text-black font-semibold">
                Admin Login 🔒
              </a>
            </li>
          </ul>
        </div>

        <!-- Newsletter -->
        <div>
          <h4 class="font-serif font-bold text-slate-900 mb-4 md:mb-6">Newsletter</h4>
          <p class="text-xs text-slate-600 mb-4 font-light">Subscribe for art drops.</p>

          {% form 'customer' %}
            <div class="flex flex-col gap-2 w-full max-w-sm">
              <input
                type="email"
                name="contact[email]"
                placeholder="Email Address"
                class="w-full border rounded-md px-4 py-2 text-sm"
                required
              >

              <button type="submit"
                class="w-full bg-black text-white rounded-md px-4 py-2 text-sm font-bold hover:opacity-80">
                Join
              </button>
            </div>
          {% endform %}
        </div>

      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-500 font-medium">
      <p>© {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>

      <div class="flex gap-6">
        <a href="/policies/privacy-policy" class="hover:text-black">Privacy Policy</a>
        <a href="/policies/terms-of-service" class="hover:text-black">Terms of Service</a>
      </div>
    </div>

  </div>
</footer>