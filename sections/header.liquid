<header class="fixed top-0 left-0 w-full z-[100] bg-background-light/90 dark:bg-background-dark/90 backdrop-blur-md border-b border-primary/20 transition-all duration-500" id="site-header">
  <div class="max-w-7xl mx-auto h-20 px-6 grid grid-cols-2 md:grid-cols-3 items-center">
    
    <!-- Logo -->
    <div class="flex justify-start">
      <a href="/" class="font-serif text-2xl font-semibold tracking-tight text-slate-900 dark:text-text-light hover:text-primary transition-colors whitespace-nowrap">
        Pristine Forests
      </a>
    </div>

    <!-- Desktop Nav - Centered -->
    <nav class="hidden md:flex justify-center gap-8">
      <a href="/pages/artists" class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">
        Artists
      </a>
    </nav>

    <!-- Actions -->
    <div class="flex justify-end items-center gap-4">
      <div class="hidden md:flex items-center gap-4">
        {% render 'dark-mode-toggle' %}
        
        <a href="/account" class="p-2 text-text-muted hover:text-primary hover:bg-primary/10 rounded-full transition-colors" title="Account">
          <span class="material-icons text-xl">account_circle</span>
        </a>
      </div>

      <!-- Mobile Menu Toggle -->
      <div class="md:hidden flex items-center gap-4">
        {% render 'dark-mode-toggle' %}
        <button class="text-text-muted hover:text-primary transition" aria-label="Toggle menu">
           <span class="material-icons text-2xl">menu</span>
        </button>
      </div>
    </div>
  </div>
</header>

<style>
  #site-header.scrolled {
    background-color: rgba(0, 0, 0, 0.85);
    height: 65px;
    border-color: rgba(255, 255, 255, 0.1);
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [],
  "presets": [
    {
      "name": "Default Header"
    }
  ]
}
{% endschema %}
