<header class="fixed top-0 inset-x-0 h-[80px] z-[100] transition-all duration-500 border-b border-white/5 backdrop-blur-md bg-transparent data-[scrolled=true]:bg-black/80 data-[scrolled=true]:h-[65px]"
        id="site-header">
  <div class="container h-full flex items-center justify-between">
    
    <!-- Logo -->
    <div class="flex justify-start">
      <a href="/" class="font-serif text-2xl font-semibold tracking-tight text-slate-900 dark:text-text-light hover:text-primary transition-colors whitespace-nowrap">
        Pristine Forests
      </a>
    </div>

    <!-- Navigation -->
    <nav class="hidden md:flex justify-center gap-8">
      <a href="/pages/artists" class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">
        Artists
      </a>
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-6">
      {% render 'dark-mode-toggle' %}
      
      <a href="/account" class="p-2 text-white/60 hover:text-white transition-colors" aria-label="Account">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      </a>

      <!-- Mobile Hamburger -->
      <button class="md:hidden p-2 text-white" aria-label="Open Menu">
         <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
           <path d="M4 8h16M4 16h16"/>
         </svg>
      </button>
    </div>
  </div>
</header>

<style>
  #site-header.scrolled {
    background-color: rgba(0, 0, 0, 0.85);
    height: 65px;
    border-color: rgba(255, 255, 255, 0.1);
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [],
  "presets": [
    {
      "name": "Default Header"
    }
  ]
}
{% endschema %}
