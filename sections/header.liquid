<header class="fixed top-0 inset-x-0 h-[80px] z-[100] transition-all duration-500 border-b border-white/5 backdrop-blur-md bg-transparent data-[scrolled=true]:bg-black/80 data-[scrolled=true]:h-[65px]"
        id="site-header">
  <div class="container h-full flex items-center justify-between">
    
    <!-- Logo -->
    <a href="/" class="flex items-center gap-4 group">
      <div class="w-10 h-10 border border-gold flex items-center justify-center p-1 group-hover:rotate-45 transition-transform">
        <svg viewBox="0 0 24 24" class="w-full h-full text-gold" fill="currentColor">
          <path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"/>
        </svg>
      </div>
      <div class="flex flex-col">
        <span class="text-xl tracking-tighter text-white font-serif uppercase leading-none">Pristine</span>
        <span class="text-xs text-gold uppercase tracking-[0.3em] font-sans leading-none">Forests</span>
      </div>
    </a>

    <!-- Navigation -->
    <nav class="hidden md:flex items-center gap-12">
      <a href="/pages/artists" class="text-xs uppercase tracking-widest text-white/60 hover:text-gold transition-colors">
        Artists
      </a>
      <a href="/collections/all" class="text-xs uppercase tracking-widest text-white/60 hover:text-gold transition-colors">
         Storefront
      </a>
      <a href="/pages/collaboration" class="text-xs uppercase tracking-widest text-white/60 hover:text-gold transition-colors">
        Collaborate
      </a>
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-6">
      {% render 'dark-mode-toggle' %}
      
      <a href="/account" class="p-2 text-white/60 hover:text-white transition-colors" aria-label="Account">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      </a>

      <!-- Mobile Hamburger -->
      <button class="md:hidden p-2 text-white" aria-label="Open Menu">
         <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
           <path d="M4 8h16M4 16h16"/>
         </svg>
      </button>
    </div>
  </div>
</header>

<style>
  #site-header.scrolled {
    background-color: rgba(0, 0, 0, 0.85);
    height: 65px;
    border-color: rgba(255, 255, 255, 0.1);
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [],
  "presets": [
    {
      "name": "Default Header"
    }
  ]
}
{% endschema %}
