{%- assign is_hover_only = false -%}
{%- if request.page_type == 'index' -%}
  {%- assign is_hover_only = true -%}
{%- elsif request.page_type == 'page' and page.handle == 'artists' -%}
  {%- assign is_hover_only = true -%}
{%- elsif request.page_type == 'metaobject' -%}
  {%- assign is_hover_only = true -%}
{%- endif -%}

<header class="fixed top-0 left-0 w-full z-100 bg-background-light/30 dark:bg-background-dark/50 backdrop-blur-md border-b border-primary/20 transition-all duration-500{% if is_hover_only %} header-hover-only{% endif %}" id="site-header">
  <div class="flex flex-col w-full">
    <!-- Top Row: Centralised Logo -->
    <div class="w-full flex justify-center py-4 border-b border-primary/10">
      <a href="/" class="hover:opacity-80 transition-opacity">
        <img 
            src="https://www.pristineforests.com/cdn/shop/files/PF_Logo_2_3.svg?v=1766045387" 
            alt="Pristine Forests Logo" 
            class="h-16 md:h-20 w-auto header-logo" 
            loading="lazy"
        />
      </a>
    </div>

    <!-- Bottom Row: Current Navbar -->
    <div class="max-w-7xl mx-auto w-full h-16 px-6 grid grid-cols-2 md:grid-cols-3 items-center border-b-0">
      
      <!-- Left (Brand/Title) -->
      <div class="flex justify-start">
        <a href="/" class="hover:opacity-80 transition-opacity flex items-center gap-3">
          <span class="font-serif text-xl font-semibold tracking-tight text-slate-900 dark:text-text-light whitespace-nowrap">
            Artist Studio
          </span>
        </a>
      </div>

      <!-- Desktop Nav - Centered -->
      <nav class="hidden md:flex justify-center gap-8">
        <a href="/collections/all" class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">
          Shop
        </a>
        <a href="/pages/artists" class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">
          Artists
        </a>
      </nav>

      <!-- Actions -->
      <div class="flex justify-end items-center gap-4">
        <div class="hidden md:flex items-center gap-4">
          {% render 'dark-mode-toggle' %}
          
          <a href="/account" class="p-2 text-text-muted hover:text-primary hover:bg-primary/10 rounded-full transition-colors" title="Account">
            <span class="material-icons text-xl">account_circle</span>
          </a>
        </div>

        <!-- Mobile Menu Toggle -->
        <div class="md:hidden flex items-center gap-4">
          {% render 'dark-mode-toggle' %}
          <button data-mobile-menu-toggle
                  class="text-text-muted hover:text-primary transition"
                  aria-label="Toggle menu"
                  aria-expanded="false">
            <span class="material-icons text-2xl" data-menu-icon-open>menu</span>
            <span class="material-icons text-2xl" data-menu-icon-close style="display:none">close</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Dropdown Menu -->
  <div data-mobile-menu
       class="md:hidden absolute top-full left-0 w-full bg-background-light dark:bg-background-dark border-b border-primary/20 shadow-lg flex-col items-center py-6 gap-6 transition-all"
       style="display:none">
    <style>
      [data-mobile-menu].is-open { display: flex !important; }
    </style>
    <a href="/collections/all"
       class="text-lg font-medium text-slate-900 dark:text-text-light hover:text-primary transition-colors">
      Shop
    </a>
    <a href="/pages/artists"
       class="text-lg font-medium text-slate-900 dark:text-text-light hover:text-primary transition-colors">
      Artists
    </a>
    <a href="/account"
       class="text-lg font-medium text-slate-900 dark:text-text-light flex items-center gap-2 hover:text-primary transition-colors">
      <span class="material-icons text-xl">account_circle</span>
      Login / Account
    </a>
  </div>
</header>

<style>
  #site-header.scrolled {
    background-color: rgba(253, 252, 251, 0.95);
    border-color: rgba(49, 84, 78, 0.15);
  }
  .dark #site-header.scrolled {
    background-color: rgba(14, 18, 14, 0.95);
    border-color: rgba(255, 255, 255, 0.1);
  }

  @media (min-width: 768px) {
    #site-header.header-hover-only {
      opacity: 0;
      transform: translateY(-10px);
    }
    #site-header.header-hover-only:hover {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [],
  "presets": [
    {
      "name": "Default Header"
    }
  ]
}
{% endschema %}
