<div class="bg-background-light dark:bg-background-dark"
     style="min-height: 100vh; padding-top: 8rem; padding-bottom: 5rem;">
  <div style="max-width: 48rem; margin: 0 auto; padding: 0 1.5rem;">
    <h1 class="font-serif reveal"
        style="font-size: clamp(2.25rem, 6vw, 3rem); font-weight: 700;
               margin-bottom: 2rem; line-height: 1.1;">
      {{ page.title }}
    </h1>
    <div class="reveal reveal-stagger-1"
         style="font-size: 1rem; line-height: 1.75; color: var(--text-muted);">
      {{ page.content }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Page Content",
  "settings": [],
  "presets": [{ "name": "Default Page" }]
}
{% endschema %}
