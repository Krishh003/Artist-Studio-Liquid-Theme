{%- liquid
  assign site_settings = shop.metaobjects['site_settings']['artist-studio-by-pristine-forests']
  assign hero_collection = section.settings.hero_collection
  if hero_collection == blank or hero_collection.products.size == 0
    assign hero_collection = collections.all
  endif
-%}

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-background-light dark:bg-background-dark transition-colors duration-300">
  
  <!-- Background Scattered Artworks -->
  {% render 'scatter-images', collection: hero_collection %}

  <!-- Hero Content -->
  <div class="container relative z-20 pointer-events-none md:pointer-events-auto">
    <div class="max-w-4xl mx-auto flex flex-col items-center text-center">
      
      <span class="text-gold uppercase tracking-[0.4em] text-xs font-semibold mb-8 reveal">
        Digital Art Collective
      </span>

      <h1 class="font-serif text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-normal leading-tight tracking-tighter text-slate-900 dark:text-text-light mb-6 uppercase reveal reveal-stagger-1">
        {{ site_settings.hero_title.value | default: "Artist Studio by Pristine Forests" }}
      </h1>

      <p class="text-sm sm:text-base text-slate-500 dark:text-text-muted max-w-md mx-auto font-normal px-4 mt-8 leading-relaxed reveal reveal-stagger-3">
        {{ site_settings.hero_description.value | default: "An initiative by Pristine Forests where art meets conscious living." }}
      </p>

      <div class="mt-10 reveal reveal-stagger-4 pointer-events-auto">
        <a href="{{ site_settings.hero_primary_button_link.value | default: "/pages/artists" }}" class="px-10 py-3 bg-[#31544E] text-white rounded-full text-xs font-semibold tracking-widest uppercase hover:bg-[#1B3B36] transition-all duration-300 inline-block">
          {{ site_settings.hero_primary_button_text.value | default: "Explore Gallery" }}
        </a>
      </div>

    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 reveal reveal-stagger-5 opacity-40" style="bottom: 3rem;">
    <span class="text-[10px] uppercase tracking-[0.3em] text-slate-900 dark:text-text-light font-medium">Scroll</span>
    <div class="w-[1px] h-12 bg-gradient-to-b from-[#C5A059] to-transparent animate-bounce"></div>
  </div>

</section>

{% schema %}
{
  "name": "Home Hero",
  "settings": [
    {
      "type": "collection",
      "id": "hero_collection",
      "label": "Hero Collection (for scattered images)"
    }
  ],
  "presets": [
    {
      "name": "Home Hero"
    }
  ]
}
{% endschema %}
