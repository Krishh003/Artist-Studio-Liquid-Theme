{%- liquid
  assign site_settings = shop.metaobjects['site_settings']['artist-studio-by-pristine-forests']
  assign hero_collection = collections[settings.hero_collection] | default: collections.all
-%}

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-black py-24 md:py-0">
  
  <!-- Background Scattered Artworks -->
  {% render 'scatter-images', collection: hero_collection %}

  <!-- Hero Content -->
  <div class="container relative z-20 pointer-events-none md:pointer-events-auto">
    <div class="max-w-4xl mx-auto flex flex-col items-center text-center">
      
      <span class="text-gold uppercase tracking-[0.4em] text-xs font-semibold mb-8 reveal">
        Digital Art Collective
      </span>

      <h1 class="text-5xl md:text-8xl text-white mb-10 leading-[0.95] reveal reveal-stagger-1">
        {{ site_settings.hero_title.value | default: "The Deepest Forest of Expression" }}
      </h1>

      <div class="h-px w-32 bg-gold/30 mb-12 reveal reveal-stagger-2"></div>

      <p class="text-white/60 text-lg md:text-xl leading-relaxed max-w-2xl mb-16 reveal reveal-stagger-3">
        {{ site_settings.hero_summary_text.value | default: "Discover a curated gallery of digital surrealism, traditional mastery, and contemporary souls." }}
      </p>

      <div class="flex flex-col md:flex-row gap-6 reveal reveal-stagger-4 pointer-events-auto">
        <a href="/pages/artists" class="bg-gold text-black px-12 py-5 uppercase tracking-widest text-sm font-bold hover:bg-white transition-colors">
          Explore Artists
        </a>
        <a href="/collections/all" class="border border-white/20 text-white px-12 py-5 uppercase tracking-widest text-sm font-bold hover:bg-white/10 transition-colors backdrop-blur-sm">
          Visit Storefront
        </a>
      </div>

    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 reveal reveal-stagger-5 opacity-40">
    <span class="text-[10px] uppercase tracking-[0.3em] text-white">Scroll</span>
    <div class="w-[1px] h-12 bg-gradient-to-b from-gold to-transparent animate-bounce"></div>
  </div>

</section>

{% schema %}
{
  "name": "Home Hero",
  "settings": [
    {
      "type": "collection",
      "id": "hero_collection",
      "label": "Hero Collection (for scattered images)"
    }
  ],
  "presets": [
    {
      "name": "Home Hero"
    }
  ]
}
{% endschema %}
