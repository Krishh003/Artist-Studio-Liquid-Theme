{%- liquid
  assign site_settings = shop.metaobjects['site_settings']['artist-studio-by-pristine-forests']
  assign hero_collection = section.settings.hero_collection
  if hero_collection == blank or hero_collection.products.size == 0
    assign hero_collection = collections.all
  endif
-%}

<section class="relative w-full min-h-screen flex items-center justify-center overflow-hidden bg-background-light dark:bg-background-dark transition-colors duration-300">
  
  <!-- Hero Content -->
  <div class="relative z-20 text-center max-w-5xl px-4 w-full h-full flex flex-col items-center justify-center pointer-events-none md:pointer-events-auto">
    <div class="mix-blend-difference text-white flex flex-col items-center">
      <h1 class="font-serif font-normal leading-tight tracking-tighter uppercase flex flex-col items-center reveal reveal-stagger-1 text-center">
        <span class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl w-full block">ARTIST STUDIO</span>
        <span class="text-2xl sm:text-3xl md:text-4xl mt-4 opacity-90 block">BY PRISTINE FORESTS</span>
      </h1>
      <p class="text-sm sm:text-base max-w-md mx-auto font-normal px-4 mt-8 leading-relaxed opacity-90 reveal reveal-stagger-3">
        {{ site_settings.hero_description.value | default: "An initiative by Pristine Forests where art meets conscious living." }}
      </p>
    </div>

    <div class="mt-12 reveal reveal-stagger-4 pointer-events-auto">
      <a href="{{ site_settings.hero_primary_button_link.value | default: '/pages/artists' }}" class="px-10 py-3 rounded-full text-xs font-semibold tracking-widest uppercase inline-block text-white bg-gradient-to-r from-white/20 to-white/5 backdrop-blur-md border border-white/30 shadow-[0_4px_30px_rgba(0,0,0,0.1)] hover:bg-white/30 hover:from-white/30 hover:to-white/10 transition-all duration-300">
        {{ site_settings.hero_primary_button_text.value | default: "Explore Gallery" }}
      </a>
    </div>
  </div>

  <!-- Full-screen background carousel -->
  <div class="absolute inset-0 w-full h-full z-0 overflow-hidden bg-black js-hero-carousel">
    {% assign carousel_count = 0 %}
    {% for product in hero_collection.products limit: 20 %}
      {% if product.featured_image %}
        {% assign img = product.featured_image %}
        {% if img.aspect_ratio >= 1.0 %}
          {% if carousel_count < 6 %}
            <div
              class="js-hero-slide absolute inset-0 w-full h-full z-0 opacity-0 pointer-events-none"
              data-index="{{ carousel_count }}"
              style="transform: scaleX(0); transform-origin: right;"
            >
              {{ img | image_url: width: 2000 | image_tag: class: 'object-cover w-full h-full', style: 'filter: blur(4px); transform: scale(1.05);', loading: 'eager' }}
            </div>
            {% assign carousel_count = carousel_count | plus: 1 %}
          {% endif %}
        {% endif %}
      {% endif %}
    {% endfor %}

    <!-- Fallback dark overlay for extra readability -->
    <div class="absolute inset-0 bg-black/30 z-20 pointer-events-none"></div>
  </div>


  {% if carousel_count > 1 %}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const slides = document.querySelectorAll('.js-hero-slide');
      if (slides.length <= 1) {
        if(slides.length === 1) {
          slides[0].className = 'js-hero-slide absolute inset-0 w-full h-full z-10 opacity-100';
          slides[0].style.transform = 'scaleX(1)';
        }
        return;
      }

      let activeIndex = 0;
      let prevIndex = null;

      function updateSlides() {
        slides.forEach((slide, i) => {
          if (i === activeIndex) {
            slide.className = 'js-hero-slide absolute inset-0 w-full h-full z-10 opacity-100';
            slide.style.transition = 'transform 1s cubic-bezier(0.65, 0, 0.35, 1)';
            slide.style.transformOrigin = 'right';
            slide.style.transform = 'scaleX(1)';
            slide.style.willChange = 'transform';
          } else if (i === prevIndex) {
            slide.className = 'js-hero-slide absolute inset-0 w-full h-full z-10 opacity-100';
            slide.style.transition = 'transform 1s cubic-bezier(0.65, 0, 0.35, 1)';
            slide.style.transformOrigin = 'left';
            slide.style.transform = 'scaleX(0)';
            slide.style.willChange = 'transform';
          } else {
            slide.className = 'js-hero-slide absolute inset-0 w-full h-full z-0 opacity-0 pointer-events-none';
            slide.style.transition = 'opacity 0.5s ease';
            slide.style.transformOrigin = 'right';
            slide.style.transform = 'scaleX(0)';
            slide.style.willChange = 'auto';
          }
        });
      }

      updateSlides();

      setInterval(() => {
        prevIndex = activeIndex;
        activeIndex = (activeIndex + 1) % slides.length;
        updateSlides();
      }, 5000);
    });
  </script>
  {% endif %}

</section>

{% schema %}
{
  "name": "Home Hero",
  "settings": [
    {
      "type": "collection",
      "id": "hero_collection",
      "label": "Hero Collection (for scattered images)"
    }
  ],
  "presets": [
    {
      "name": "Home Hero"
    }
  ]
}
{% endschema %}
