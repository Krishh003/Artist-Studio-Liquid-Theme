{%- liquid
  assign artist_handle = product.metafields.custom.artist_handle.value | default: product.vendor | handleize
  assign artwork_medium = product.metafields.custom.medium.value | default: 'Digital Mixed Media'
  assign artwork_dimensions = product.metafields.custom.dimensions.value | default: 'Dimensions on Request'
  assign date_created = product.metafields.custom.date_created.value
  assign artwork_year = date_created | date: '%Y' | default: 'N/A'
  assign main_image = product.featured_image
-%}

<div class="min-h-screen flex flex-col md:flex-row overflow-hidden bg-background-light dark:bg-background-dark transition-colors">

  <!-- Left: Image (50%) -->
  <div class="artwork-reveal w-full md:w-1/2 h-[60vh] md:h-screen relative p-6 md:p-12 lg:p-20 flex items-center justify-center bg-background-accent/30"
       style="opacity:0; transform: translateX(-50px);">

    <!-- Back to Gallery -->
    <a href="/artist/{{ artist_handle }}"
       class="absolute top-6 left-6 z-50 flex items-center gap-2 text-slate-500 dark:text-text-muted hover:text-primary transition-colors">
      <span class="material-icons text-sm">arrow_back</span>
      <span class="text-xs font-bold tracking-widest uppercase">Back to Gallery</span>
    </a>

    <div class="image-zoom-container relative w-full h-full flex items-center justify-center overflow-hidden rounded-lg shadow-[0_35px_60px_-15px_rgba(0,0,0,0.5)]"
         style="max-width: 100%; max-height: 100%;">
      <img class="zoom-target block max-w-full max-h-full w-auto h-auto object-contain cursor-zoom-in transition-transform duration-700"
           src="{{ main_image | image_url: width: 1600 }}"
           alt="{{ product.title | escape }}"
           loading="eager"
           width="{{ main_image.width }}"
           height="{{ main_image.height }}">
    </div>
  </div>

  <!-- Right: Details (50%) -->
  <div class="artwork-reveal w-full md:w-1/2 h-auto md:h-screen overflow-y-auto p-6 md:p-12 lg:p-24 flex flex-col justify-center bg-background-light dark:bg-background-dark"
       style="opacity:0; transform: translateY(50px); transition-delay: 0.2s;">
    <div class="max-w-xl">

      <!-- Artist link -->
      <a href="/artist/{{ artist_handle }}"
         class="text-primary text-xs font-bold tracking-[0.2em] uppercase mb-4 block hover:underline">
        {{ product.vendor }}
      </a>

      <!-- Title -->
      <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-slate-900 dark:text-white mb-6 leading-tight">
        {{ product.title }}
      </h1>

      <!-- Metadata row -->
      <div class="flex flex-wrap gap-4 sm:gap-8 text-sm text-slate-500 dark:text-text-muted border-b border-black/10 dark:border-white/10 pb-8 mb-8">
        <div>
          <span class="block text-xs uppercase tracking-wider opacity-60 mb-1">Year</span>
          <span class="font-semibold text-slate-900 dark:text-white">{{ artwork_year }}</span>
        </div>
        <div>
          <span class="block text-xs uppercase tracking-wider opacity-60 mb-1">Medium</span>
          <span class="font-semibold text-slate-900 dark:text-white">{{ artwork_medium }}</span>
        </div>
        <div>
          <span class="block text-xs uppercase tracking-wider opacity-60 mb-1">Dimensions</span>
          <span class="font-semibold text-slate-900 dark:text-white">{{ artwork_dimensions }}</span>
        </div>
      </div>

      <!-- Description -->
      <div class="text-sm text-slate-600 dark:text-text-muted font-light leading-relaxed mb-12">
        {% if product.description != blank %}
          {{ product.description }}
        {% else %}
          <p>No description available for this artwork.</p>
        {% endif %}
      </div>

      <!-- Inquiry -->
      <div class="w-full mt-4">
        <div>
          <span class="block text-xs uppercase tracking-wider opacity-60 mb-1">Price</span>
          <span class="font-serif text-3xl text-slate-900 dark:text-white">
            {% if product.price > 0 %}
              ₹ {{ product.price | money_without_currency | remove: ',' | times: 1 | round: 0 }}
            {% else %}
              Price on Request
            {% endif %}
          </span>
        </div>
        <a href="mailto:pankaj.saroj@hotmail.com?subject={{ 'Inquiry: ' | append: product.title | append: ' by ' | append: product.vendor | url_encode }}"
           class="block w-full bg-slate-900 dark:bg-white text-white dark:text-background-dark py-4 px-6 rounded-lg font-bold text-sm tracking-widest uppercase hover:bg-primary hover:text-white transition-all duration-300 text-center">
          Inquire About Artwork
        </a>
      </div>

    </div>
  </div>

</div>

{% schema %}
{
  "name": "Artwork Detail",
  "settings": [],
  "presets": [
    {
      "name": "Artwork Detail"
    }
  ]
}
{% endschema %}
