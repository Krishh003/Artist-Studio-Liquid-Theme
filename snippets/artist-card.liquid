{% comment %}
  Parameters:
    - artist: The metaobject for the artist
    - index: The loop index for staggered animation
{% endcomment %}

<a href="{{ artist.system.url | default: '/artist/' | append: artist.handle }}"
   class="artist-card-reveal block relative group h-[500px] overflow-hidden grayscale hover:grayscale-0 transition-all duration-700 reveal"
   data-index="{{ index }}"
   style="transition-delay: {{ index | times: 100 }}ms;">
  
  <div class="absolute inset-0 z-0">
    {% if artist.profile_image != blank %}
      {{ artist.profile_image.value | image_url: width: 800 | image_tag: 
         class: 'w-full h-full object-cover transition-transform duration-700 group-hover:scale-110',
         loading: 'lazy'
      }}
    {% else %}
      <div class="w-full h-full bg-gray-200"></div>
    {% endif %}
  </div>

  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent z-10"></div>

  <div class="absolute bottom-0 left-0 right-0 p-8 z-20 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
    <span class="text-gold uppercase tracking-widest text-xs mb-2 block">
      {{ artist.category.value | default: "Featured Artist" }}
    </span>
    <h3 class="text-3xl text-white mb-2">
      {{ artist.name.value }}
    </h3>
    <div class="text-white/60 text-sm line-clamp-2 max-w-md opacity-0 group-hover:opacity-100 transition-opacity duration-500">
      {{ artist.bio.value | truncatewords: 20 }}
    </div>
  </div>
</a>

<style>
  .artist-card-reveal.reveal {
    opacity: 0;
    transform: translateY(30px);
  }
  .artist-card-reveal.reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  
  .grayscale { filter: grayscale(100%); }
  .group:hover .grayscale { filter: grayscale(0%); }

  /* Utility if Tailwind missing */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
