{% comment %}
  Parameters:
    - artist: The metaobject for the artist
    - index: The loop index for staggered entrance delay
{% endcomment %}

<a href="{{ artist.system.url | default: '/artists/' | append: artist.handle }}"
   class="artist-card-reveal group"
   data-index="{{ index }}"
   style="display: block; position: relative; height: 500px;
          overflow: hidden; border-radius: 1rem; cursor: pointer;">

  <!-- Artist image (grayscale → full color on hover) -->
  <div style="position: absolute; inset: 0; z-index: 0;">
    {% if artist.profile_image != blank %}
      {{ artist.profile_image.value | image_url: width: 800 | image_tag:
         class: 'artist-card-img',
         loading: 'lazy',
         width: 800,
         height: 800
      }}
    {% else %}
      <div style="width: 100%; height: 100%; background: #e2e8f0;"></div>
    {% endif %}
  </div>

  <!-- Gradient overlay -->
  <div style="position: absolute; inset: 0; z-index: 1;
              background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);"></div>

  <!-- Content (pinned to bottom) -->
  <div style="position: absolute; bottom: 0; left: 0; right: 0;
              padding: 2rem; z-index: 2;
              display: flex; flex-direction: column;">

    <!-- Category -->
    <span class="artist-card-category"
          style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.2em;
                 text-transform: uppercase; color: var(--primary);
                 display: block; margin-bottom: 0.5rem;">
      {{ artist.category.value | default: "Featured Artist" }}
    </span>

    <!-- Artist name -->
    <h3 style="font-size: clamp(1.875rem, 3vw, 3rem); font-family: var(--font-serif);
               color: white; font-weight: 700; margin-bottom: 1rem; line-height: 1.1;">
      {{ artist.name.value }}
    </h3>

    <!-- Bio excerpt (60% opacity at rest, full on hover) -->
    <div class="artist-card-bio"
         style="color: rgba(255,255,255,0.6); font-size: 0.875rem; font-weight: 300;
                line-height: 1.625; margin-bottom: 1.5rem; max-width: 28rem;
                display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
                overflow: hidden; transition: opacity 0.3s ease;">
      {{ artist.bio.value | truncatewords: 25 }}
    </div>

    <!-- CTA -->
    <div style="display: flex; align-items: center; gap: 0.75rem;
                color: white; font-size: 0.75rem; font-weight: 700;
                letter-spacing: 0.2em; text-transform: uppercase;">
      <span>View Portfolio</span>
      <span class="artist-card-arrow material-icons"
            style="font-size: 1rem; transition: transform 0.15s ease;">arrow_forward</span>
    </div>

  </div>
</a>

<style>
  /* Entrance animation state — toggled by artists-list.js */
  .artist-card-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease, box-shadow 0.3s ease;
  }
  .artist-card-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Image: grayscale by default, full color + zoom on hover */
  .artist-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: filter 0.7s ease, transform 0.7s ease;
  }
  .artist-card-reveal:hover .artist-card-img {
    filter: grayscale(0%);
    transform: scale(1.05);
  }

  /* Bio opacity: 60% → 100% on hover */
  .artist-card-bio { opacity: 0.6; }
  .artist-card-reveal:hover .artist-card-bio { opacity: 1; }

  /* Arrow slides right on hover */
  .artist-card-reveal:hover .artist-card-arrow {
    transform: translateX(0.5rem);
  }

  /* Box shadow lift */
  .artist-card-reveal:hover {
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
  }

  /* Line clamp fallback */
  .artist-card-bio {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
