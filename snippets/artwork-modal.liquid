<div id="artwork-modal" class="hidden fixed inset-0 z-[200] bg-black/95 backdrop-blur-xl flex flex-col md:flex-row p-4 md:p-12 overflow-y-auto">
  
  <!-- Close Button -->
  <button id="modal-close" class="absolute top-8 right-8 z-[210] p-4 text-white hover:rotate-90 transition-transform">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M18 6L6 18M6 6l12 12"/>
    </svg>
  </button>

  <!-- Image Section (60%) -->
  <div class="w-full md:w-[60%] h-[50vh] md:h-full flex items-center justify-center p-4">
    <div class="relative w-full h-full max-w-4xl flex items-center justify-center">
       <img id="modal-image" src="" alt="" 
            class="max-w-full max-h-full object-contain shadow-2xl transition-all duration-500 rounded-sm"
            data-colorthief-target>
    </div>
  </div>

  <!-- Content Section (40%) -->
  <div class="w-full md:w-[40%] flex flex-col justify-center p-8 md:p-16 text-white reveal-modal">
    <span id="modal-price" class="text-gold font-mono text-xl mb-4 dynamic-accent"></span>
    <h2 id="modal-title" class="text-4xl md:text-6xl mb-8 leading-tight"></h2>
    
    <div class="h-px w-24 bg-gold mb-8 dynamic-accent-bg"></div>
    
    <p id="modal-desc" class="text-white/60 text-lg leading-relaxed mb-12 max-w-lg"></p>
    
    <div class="flex gap-4">
      <button class="bg-gold text-black px-10 py-4 uppercase tracking-widest text-sm hover:bg-white transition-colors dynamic-accent-bg"
              data-inquiry-button>
        Inquiry Details
      </button>
    </div>
  </div>
</div>

<style>
  #artwork-modal:not(.hidden) {
    display: flex;
    animation: scale-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Dynamic variables set by JS */
  #artwork-modal {
    --accent-color: var(--gold-primary);
  }
</style>
