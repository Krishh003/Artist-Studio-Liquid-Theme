<div id="artwork-modal" class="hidden fixed inset-0 z-[200] bg-black/95 backdrop-blur-xl flex items-center justify-center px-4 py-8 md:px-8 md:py-10 overflow-y-auto">
  
  <!-- Close Button -->
  <button id="modal-close" class="absolute top-8 right-8 z-[210] p-4 text-white/50 hover:text-white transition-colors">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M18 6L6 18M6 6l12 12"/>
    </svg>
  </button>

  <div class="modal-shell relative w-full max-w-7xl max-h-full flex flex-col md:flex-row items-start gap-6 md:gap-12 overflow-y-auto md:overflow-visible">
    <!-- Image Section -->
    <div class="w-full md:w-[60%] flex justify-center">
      <div class="relative w-full flex items-center justify-center">
         <img id="modal-image" src="" alt="" 
              class="max-w-full max-h-[50vh] md:max-h-[80vh] object-contain shadow-[0_0_80px_rgba(0,0,0,0.5)] transition-all duration-500 rounded-lg"
              data-colorthief-target>
      </div>
    </div>

    <!-- Content Section -->
    <div class="w-full md:w-[40%] space-y-8 text-white reveal-modal">
      <div class="space-y-2">
        <span id="modal-kicker" class="text-xs font-bold uppercase tracking-[0.3em] dynamic-accent">Viewing Piece</span>
        <h2 id="modal-title" class="font-serif text-4xl md:text-6xl leading-tight"></h2>
        <p id="modal-artist" class="text-white/40 font-mono text-sm tracking-widest uppercase"></p>
      </div>

      <div class="space-y-4">
        <p id="modal-desc" class="text-white/60 text-sm leading-relaxed max-w-sm"></p>
      </div>

      <div class="pt-2">
        <a href="#"
           class="inline-block bg-white text-black px-8 py-4 rounded-full font-bold uppercase tracking-[0.2em] text-[10px] transition-all hover:scale-[1.02] active:scale-[0.98]"
           data-artwork-link>
          Inquire Details
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  #artwork-modal:not(.hidden) {
    display: flex;
    animation: scale-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Dynamic variables set by JS */
  #artwork-modal {
    --accent-color: var(--gold-primary);
  }
</style>
