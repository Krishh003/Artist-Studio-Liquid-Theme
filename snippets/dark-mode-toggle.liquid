<button id="dark-mode-toggle" class="dark-mode-btn" aria-label="Toggle theme">
    <!-- Light Mode Icon (Visible by default) -->
    <span class="material-icons text-xl icon-light">light_mode</span>
    <!-- Dark Mode Icon (Visible in Dark Mode) -->
    <span class="material-icons text-xl icon-dark">dark_mode</span>
</button>

<style>
  .dark-mode-btn {
    position: relative;
    display: flex;
    height: 2.5rem;
    width: 2.5rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    transition: background-color 0.3s;
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .dark-mode-btn:hover { background-color: rgba(0, 0, 0, 0.05); }
  .dark .dark-mode-btn:hover { background-color: rgba(255, 255, 255, 0.1); }

  #dark-mode-toggle .material-icons {
    pointer-events: none;
    position: absolute;
    transition: transform 0.5s ease;
  }

  .icon-light { 
    transform: rotate(0deg) scale(1); 
    color: var(--primary); 
  }
  .icon-dark { 
    transform: rotate(90deg) scale(0); 
    color: var(--primary); 
  }

  .dark .icon-light { 
    transform: rotate(-90deg) scale(0); 
    color: var(--gold-primary); 
  }
  .dark .icon-dark { 
    transform: rotate(0deg) scale(1); 
    color: var(--gold-primary); 
  }
</style>
