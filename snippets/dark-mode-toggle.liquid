<button
    id="dark-mode-toggle"
    class="relative flex h-8 w-8 items-center justify-center rounded-full transition-colors hover:bg-black/5 dark:hover:bg-white/10"
    aria-label="Toggle theme"
>
    <!-- Light Mode Icon (Visible by default) -->
    <span class="material-icons text-xl transform transition-transform duration-500 rotate-0 dark:-rotate-90 scale-100 dark:scale-0 absolute text-primary dark:text-gold-light">
        light_mode
    </span>
    <!-- Dark Mode Icon (Visible in Dark Mode) -->
    <span class="material-icons text-xl transform transition-transform duration-500 rotate-90 dark:rotate-0 scale-0 dark:scale-100 absolute text-primary dark:text-gold-light">
        dark_mode
    </span>
</button>

<style>
  #dark-mode-toggle .material-icons {
    pointer-events: none;
  }
</style>
