{% comment %}
  Parameters:
    - artworks (Products/Metaobjects list): The artworks to display
    - speed (string): Animation duration like '20s' (default)
{% endcomment %}

<div class="carousel-wrapper relative w-full overflow-hidden py-4">
  <div class="carousel-content animate-carousel-horizontal flex flex-row gap-6 w-max"
       style="animation-duration: {{ speed | default: '30s' }};">
    
    {% comment %} Triple duplication for infinite scroll {% endcomment %}
    {% for i in (1..3) %}
      <div class="flex flex-row gap-6">
        {% for artwork in artworks limit: 4 %}
          <div class="carousel-item relative group h-[120px] md:h-[160px] lg:h-[180px] w-auto flex-shrink-0 overflow-hidden rounded-sm border-[1.5px] border-[#C5A059] shadow-lg">
            {% if artwork.featured_image != blank %}
              <img src="{{ artwork.featured_image | image_url: height: 800 }}" 
                   alt="{{ artwork.title | escape }}"
                   class="h-full w-auto max-w-none object-cover transition-transform duration-700 group-hover:scale-[1.03]"
                   loading="lazy">
            {% else %}
               <!-- Placeholder or specific metaobject field -->
               <img src="{{ artwork.preview_image.value | image_url: height: 800 }}" 
                    class="h-full w-auto max-w-none object-cover">
            {% endif %}
            
            <div class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
              <span class="text-white text-sm font-semibold block truncate">{{ artwork.title }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .carousel-wrapper {
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
</style>
