{% comment %}
  Parameters:
    - artworks (Products/Metaobjects list): The artworks to display
    - speed (string): Animation duration like '20s' (default)
{% endcomment %}

<div class="carousel-wrapper relative w-full overflow-hidden py-4">
  <div class="carousel-content animate-carousel-horizontal flex flex-row gap-6 w-max"
       style="animation-duration: {{ speed | default: '30s' }};">
    
    {% comment %} Triple duplication for infinite scroll, but only if we have artworks {% endcomment %}
    {% if artworks != blank and artworks.size > 0 %}
      {% for i in (1..3) %}
        <div class="flex flex-row gap-6">
          {% for artwork in artworks limit: 12 %}
            {%- liquid
              assign artwork_img = ""
              if artwork.featured_image != blank
                assign artwork_img = artwork.featured_image
              elsif artwork.preview_image.value != blank
                assign artwork_img = artwork.preview_image.value
              elsif artwork.preview_image != blank
                assign artwork_img = artwork.preview_image
              elsif artwork.image.value != blank
                assign artwork_img = artwork.image.value
              elsif artwork.image != blank
                assign artwork_img = artwork.image
              elsif artwork.featured_media != blank
                assign artwork_img = artwork.featured_media.preview_image
              endif
            -%}
            <div class="carousel-item relative group h-40 md:h-48 lg:h-56 w-auto flex-shrink-0 overflow-hidden rounded-sm border-[1.5px] border-[#C5A059] shadow-lg">
              {% if artwork_img != blank %}
                <img src="{{ artwork_img | image_url: height: 1000 }}" 
                     alt="{{ artwork.title | default: artwork.name | escape }}"
                     class="h-full w-auto max-w-none object-cover transition-transform duration-700 group-hover:scale-[1.03]"
                     loading="lazy"
                     width="{{ artwork_img.width | default: 800 }}"
                     height="{{ artwork_img.height | default: 1000 }}">
              {% else %}
                  <div class="h-full w-[120px] bg-slate-200 dark:bg-primary/20 flex items-center justify-center text-slate-400">
                    <span class="material-symbols-outlined opacity-20">image</span>
                  </div>
              {% endif %}
              
            </div>
          {% endfor %}
        </div>
      {% endfor %}
    {% else %}
       <div class="flex items-center justify-center py-12 w-full">
         <p class="text-slate-400 text-xs uppercase tracking-widest italic">No artworks found for this artist.</p>
       </div>
    {% endif %}

  </div>
</div>

<style>
  .carousel-wrapper {
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
</style>
