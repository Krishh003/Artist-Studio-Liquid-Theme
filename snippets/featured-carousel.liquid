{% comment %}
  Parameters:
    - artworks (Products/Metaobjects list): The artworks to display
    - speed (string): Animation duration like '20s' (default)
{% endcomment %}

<div class="carousel-wrapper relative h-[600px] md:h-screen w-full overflow-hidden">
  <div class="carousel-content animate-carousel-vertical flex flex-col gap-8"
       style="animation-duration: {{ speed | default: '30s' }};">
    
    {% comment %} Triple duplication for infinite scroll {% endcomment %}
    {% for i in (1..3) %}
      <div class="flex flex-col gap-8">
        {% for artwork in artworks limit: 10 %}
          <div class="carousel-item relative group aspect-square flex-shrink-0">
            {% if artwork.featured_image != blank %}
              <img src="{{ artwork.featured_image | image_url: width: 600 }}" 
                   alt="{{ artwork.title | escape }}"
                   class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                   loading="lazy">
            {% else %}
               <!-- Placeholder or specific metaobject field -->
               <img src="{{ artwork.preview_image.value | image_url: width: 600 }}" 
                    class="w-full h-full object-cover">
            {% endif %}
            
            <div class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
              <span class="text-white text-xs block truncate">{{ artwork.title }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .carousel-wrapper {
    mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
  }
</style>
