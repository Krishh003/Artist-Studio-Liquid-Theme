{% comment %}
  Parameters:
    - product: The product object for the artwork
    - index:   Card index (0-based) for staggered entrance delay
{% endcomment %}

<div class="artwork-card artwork-thumb group"
     data-index="{{ index | default: 0 }}"
     data-artwork-id="{{ product.id }}"
     data-image="{{ product.featured_image | image_url: width: 1200 }}"
     data-title="{{ product.title | escape }}"
     data-artist="{{ artist.name.value | default: product.vendor | escape }}"
     data-description="{{ product.description | strip_html | truncatewords: 50 | escape }}"
     data-url="{{ product.url }}"
     style="break-inside: avoid; border-radius: 2rem; overflow: hidden;
            border: 1px solid rgba(0,0,0,0.05); cursor: pointer; position: relative;
            margin-bottom: 2rem; display: block;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
            transition: box-shadow 0.5s ease;">
  <div class="dark-border-override"></div>

  <!-- Artwork image -->
  <img src="{{ product.featured_image | image_url: width: 800 }}"
       alt="{{ product.title | escape }}"
       width="800" height="800"
       loading="lazy"
       style="width: 100%; height: auto; display: block;
              transition: transform 1s ease;">

  <!-- Hover overlay -->
  <div class="card-hover-overlay"
       style="position: absolute; inset: 0;
              background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);
              transition: opacity 0.5s ease;
              display: flex; flex-direction: column;
              justify-content: flex-end; padding: 2rem;">
    <h3 style="color: white; font-family: var(--font-serif); font-size: 1.25rem;
                margin-bottom: 0.25rem; transition: transform 0.5s ease;">
      {{ product.title }}
    </h3>
    <p style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.2em;
               color: rgba(255,255,255,0.6);
               transition: transform 0.5s ease 0.075s;">
      Explore Subject
    </p>
  </div>
</div>
